#
# Tcl package index file
#
package ifneeded @PACKAGE_NAME@ @PACKAGE_VERSION@ [list source [file join $dir filewatch.tcl]]

if {$::tcl_platform(os) eq "Linux"} {
	# If running on linux, provide this package under the old name "inotify" for backwards compatibility
	# On linux, package "inotify" is provided by filewatch in addition to "filewatch"
	package ifneeded inotify @PACKAGE_VERSION@ {package require -exact @PACKAGE_NAME@ @PACKAGE_VERSION@}
}
