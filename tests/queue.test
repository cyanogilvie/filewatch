# vim: ft=tcl foldmethod=marker foldmarker=<<<,>>> shiftwidth=4 ts=4

if {[lsearch [namespace children] ::tcltest] == -1} {
	package require tcltest 2.2.5
	namespace import ::tcltest::*
}


set tmpdir [makeDirectory queue_tmp]

::tcltest::loadTestedCommands

# These tests exercise inotify::queue which is inotify-specific
::tcltest::testConstraint inotify [expr {[namespace which -command ::inotify::create_queue] ne ""}]

test queue-1.1 {Create and destroy queue object} -constraints inotify -body { #<<<
	set q	[inotify::queue new [list apply {ev {}}]]
	info object isa object $q
} -cleanup {
	if {[info exists q] && [info object isa object $q]} {$q destroy}
	unset -nocomplain q
} -result 1
#>>>
test queue-1.2 {Queue delivers events via callback} -constraints inotify -setup { #<<<
	set ::received {}
	set q	[inotify::queue new [list apply {ev {
		lappend ::received [dict get $ev mask]
		if {"IN_DELETE" in [dict get $ev mask]} {set ::done 1}
	}}]]
	$q add_watch $tmpdir {IN_CREATE IN_DELETE}
} -body {
	close [open [file join $tmpdir q_test] w]
	file delete [file join $tmpdir q_test]

	after 300 {set ::done timeout}
	vwait ::done

	set got_create	[expr {"IN_CREATE" in $::received}]
	set got_delete	[expr {"IN_DELETE" in $::received}]
	list $got_create $got_delete
} -cleanup {
	if {[info exists q] && [info object isa object $q]} {$q destroy}
	unset -nocomplain q ::received ::done got_create got_delete
} -result {1 1}
#>>>
test queue-1.3 {Queue add_watch and rm_watch by path} -constraints inotify -setup { #<<<
	set q	[inotify::queue new [list apply {ev {
		lappend ::received [dict get $ev mask]
	}}]]
} -body {
	$q add_watch $tmpdir {IN_CREATE}
	$q rm_watch $tmpdir

	set ::received {}
	close [open [file join $tmpdir q_rm_test] w]

	after 200 {set ::done 1}
	vwait ::done

	# After rm_watch, should not receive IN_CREATE
	expr {"IN_CREATE" in $::received}
} -cleanup {
	file delete -force [file join $tmpdir q_rm_test]
	if {[info exists q] && [info object isa object $q]} {$q destroy}
	unset -nocomplain q ::received ::done
} -result 0
#>>>
test queue-1.4 {Queue destroy cleans up channel} -constraints inotify -body { #<<<
	set q	[inotify::queue new [list apply {ev {}}]]
	set before	[llength [chan names]]
	$q destroy
	set after	[llength [chan names]]
	expr {$after < $before}
} -cleanup {
	unset -nocomplain q before after
} -result 1
#>>>
test queue-1.5 {Queue callback receives path in event} -constraints inotify -setup { #<<<
	set ::ev_path {}
	set q	[inotify::queue new [list apply {ev {
		set ::ev_path [dict get $ev path]
		set ::done 1
	}}]]
	$q add_watch $tmpdir {IN_CREATE}
} -body {
	close [open [file join $tmpdir path_test] w]

	after 300 {set ::done timeout}
	vwait ::done
	set ::ev_path
} -cleanup {
	file delete -force [file join $tmpdir path_test]
	if {[info exists q] && [info object isa object $q]} {$q destroy}
	unset -nocomplain q ::ev_path ::done
} -result $tmpdir
#>>>
test queue-1.6 {Queue callback receives filename in event} -constraints inotify -setup { #<<<
	set ::ev_name {}
	set q	[inotify::queue new [list apply {ev {
		set ::ev_name [dict get $ev name]
		set ::done 1
	}}]]
	$q add_watch $tmpdir {IN_CREATE}
} -body {
	close [open [file join $tmpdir name_test.txt] w]

	after 300 {set ::done timeout}
	vwait ::done
	set ::ev_name
} -cleanup {
	file delete -force [file join $tmpdir name_test.txt]
	if {[info exists q] && [info object isa object $q]} {$q destroy}
	unset -nocomplain q ::ev_name ::done
} -result name_test.txt
#>>>

::tcltest::cleanupTests
return
