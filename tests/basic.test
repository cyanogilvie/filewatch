# vim: ft=tcl foldmethod=marker foldmarker=<<<,>>> shiftwidth=4 ts=4

if {[lsearch [namespace children] ::tcltest] == -1} {
	package require tcltest 2.2.5
	namespace import ::tcltest::*
}


set tmpdir [makeDirectory tmp]

::tcltest::loadTestedCommands

# Low-level C API tests <<<
test basic-1.1 {Add and remove a watch} -setup { #<<<
	set queue	[inotify::create_queue]
} -body {
	set wd	[inotify::add_watch $queue $tmpdir {IN_ALL_EVENTS}]
	inotify::rm_watch $queue $wd
} -cleanup {
	if {[info exists queue]} {close $queue; unset queue}
} -result {0}
#>>>
test basic-1.2 {Detect a file creation in a dir} -setup { #<<<
	set queue	[inotify::create_queue]
	chan configure $queue \
			-blocking		0 \
			-buffering		none \
			-translation	binary
	set wd	[inotify::add_watch $queue $tmpdir {IN_ALL_EVENTS}]
	set wd_map($wd)	$tmpdir

	set ::tmp	"\n"
	proc readable {fd} {
		if {[eof $fd]} {
			set ::done -2
			return
		}
		set dat	[read $fd]
		set events	[inotify::decode_events $dat]
		set all_done	0
		foreach event $events {
			set wd	[lindex $event 0]
			if {[info exists ::wd_map($wd)]} {
				set event	[lreplace $event 0 0 $::wd_map($wd)]
			}
			append ::tmp "Event:\n\t[join $event \n\t]\n--------------\n"
			if {[lsearch [lindex $event 1] IN_DELETE] != -1} {
				set all_done	1
			}
		}
		if {$all_done} {
			set ::done $::tmp
		}
	}
} -body {
	chan event $queue readable [list readable $queue]
	set fp	[open [file join $tmpdir foo] a]
	puts $fp "dummy"
	close $fp

	file delete [file join $tmpdir foo]

	after 300 {set ::done -1}

	vwait ::done
	set ::done
} -cleanup {
	inotify::rm_watch $queue $wd
	if {[info exists queue]} {close $queue}
	rename readable {}
	unset -nocomplain ::done ::tmp queue wd ::wd_map fp
} -result [string map [list %tmpdir% $tmpdir] {
Event:
	%tmpdir%
	IN_CREATE
	0
	foo
--------------
Event:
	%tmpdir%
	IN_OPEN
	0
	foo
--------------
Event:
	%tmpdir%
	IN_MODIFY
	0
	foo
--------------
Event:
	%tmpdir%
	IN_CLOSE_WRITE
	0
	foo
--------------
Event:
	%tmpdir%
	IN_DELETE
	0
	foo
--------------
}]
#>>>
test basic-1.3 {Ensemble interface works} -setup { #<<<
	set queue	[inotify create_queue]
} -body {
	set wd	[inotify add_watch $queue $tmpdir {IN_ALL_EVENTS}]
	inotify rm_watch $queue $wd
} -cleanup {
	if {[info exists queue]} {close $queue}
	unset -nocomplain queue wd
} -result {0}
#>>>
test basic-1.4 {Selective mask} -setup { #<<<
	set queue	[inotify create_queue]
	chan configure $queue -blocking 0 -buffering none -translation binary
	set wd	[inotify add_watch $queue $tmpdir {IN_CREATE IN_DELETE}]
} -body {
	chan event $queue readable [list apply {{fd} {
		foreach event [inotify decode_events [read $fd]] {
			lappend ::events [lindex $event 1]
		}
		if {[llength $::events] >= 2} {set ::done 1}
	}} $queue]
	set ::events {}

	close [open [file join $tmpdir sel_test] w]
	file delete [file join $tmpdir sel_test]

	after 300 {set ::done timeout}
	vwait ::done
	set ::events
} -cleanup {
	inotify rm_watch $queue $wd
	close $queue
	unset -nocomplain queue wd ::events ::done
} -result {IN_CREATE IN_DELETE}
#>>>
# >>>

# Error path tests <<<
test error-2.1 {create_queue wrong # args} -body { #<<<
	inotify create_queue extra
} -returnCodes error -match glob -result {*create_queue*} -errorCode {TCL WRONGARGS}
#>>>
test error-2.2 {add_watch wrong # args} -body { #<<<
	inotify add_watch
} -returnCodes error -match glob -result {*queue path mask*} -errorCode {TCL WRONGARGS}
#>>>
test error-2.3 {add_watch bad channel} -body { #<<<
	inotify add_watch nosuch /tmp IN_CREATE
} -returnCodes error -match glob -result {*nosuch*} -errorCode {TCL LOOKUP CHANNEL nosuch}
#>>>
test error-2.4 {add_watch bad mask bit} -setup { #<<<
	set queue	[inotify create_queue]
} -body {
	inotify add_watch $queue $tmpdir BOGUS
} -cleanup {
	close $queue
	unset -nocomplain queue
} -returnCodes error -match glob -result {bad mask bit "BOGUS":*} -errorCode {TCL LOOKUP INDEX {mask bit} BOGUS}
#>>>
test error-2.5 {add_watch nonexistent path} -setup { #<<<
	set queue	[inotify create_queue]
} -body {
	inotify add_watch $queue /nonexistent/path IN_CREATE
} -cleanup {
	close $queue
	unset -nocomplain queue
} -returnCodes error -errorCode {POSIX ENOENT *} -match glob -result {inotify_add_watch:*}
#>>>
test error-2.6 {rm_watch wrong # args} -body { #<<<
	inotify rm_watch
} -returnCodes error -match glob -result {*queue wd*} -errorCode {TCL WRONGARGS}
#>>>
test error-2.7 {rm_watch bad wd} -setup { #<<<
	set queue	[inotify create_queue]
} -body {
	inotify rm_watch $queue 99999
} -cleanup {
	close $queue
	unset -nocomplain queue
} -returnCodes error -errorCode {POSIX EINVAL *} -match glob -result {inotify_rm_watch:*}
#>>>
test error-2.8 {decode_events wrong # args} -body { #<<<
	inotify decode_events
} -returnCodes error -match glob -result {*inotify decode_events raw_event_data*} -errorCode {TCL WRONGARGS}
#>>>
test error-2.9 {rm_watch non-integer wd} -setup { #<<<
	set queue	[inotify create_queue]
} -body {
	inotify rm_watch $queue notanumber
} -cleanup {
	close $queue
	unset -nocomplain queue
} -returnCodes error -match glob -result {*notanumber*} -errorCode {TCL VALUE *}
#>>>
# >>>

::tcltest::cleanupTests
return
